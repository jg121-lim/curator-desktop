{
  "name": "curator-desktop-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "build:desktop": "npm --workspace apps/desktop run build",
    "dev:backend": "cd apps/backend && uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:desktop\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
